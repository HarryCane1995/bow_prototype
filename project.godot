"events": [Object(InputEventKey,"resource_local_to_scene":false,"physical_keycode":65)
]
}
move_right={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"physical_keycode":68)
]
}
jump={
